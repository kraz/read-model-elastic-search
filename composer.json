{
    "name": "kraz/read-model-elastic-search",
    "description": "Read Model Elasticsearch implementation",
    "keywords": [
        "read",
        "model",
        "read-model",
        "elasticsearch"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Krasen Borisov",
            "email": "krasen.borisov@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-mbstring": "*",
        "kraz/elastic-search-client": "^1.0",
        "kraz/read-model": "^1.0"
    },
    "require-dev": {
        "doctrine/coding-standard": "^14.0",
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.1",
        "symfony/psr-http-message-bridge": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Kraz\\ReadModelElasticSearch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kraz\\ReadModelElasticSearch\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable"
}
